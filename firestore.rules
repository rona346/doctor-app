rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isAdmin() {
      return (request.auth.token.email == "guptaronak810@gmail.com" && request.auth.token.email_verified == true) ||
             (isAuthenticated() && 
              exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isDoctor() {
      return hasRole('doctor');
    }

    function isPatient() {
      return hasRole('patient');
    }

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // /users/{userId}: { uid, email, role, ... }
    // /appointments/{id}: { patientId, doctorId, status, ... }
    // /diagnoses/{id}: { patientId, doctorId, ... }
    // /prescriptions/{id}: { patientId, doctorId, ... }
    // /chats/{chatId}/messages/{msgId}: { senderId, ... }

    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'doctor', 'patient'] &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('photoURL' in data) || data.photoURL is string);
    }

    function isChatParticipant(chatId) {
      return isAuthenticated() && (
        chatId == 'doctor_patient_123' || 
        chatId.split('_').hasAny([request.auth.uid]) || 
        isAdmin()
      );
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /appointments/{id} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.patientId || 
        request.auth.uid == resource.data.doctorId || 
        isAdmin()
      );
      allow create: if isPatient() && request.resource.data.patientId == request.auth.uid;
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.patientId || 
        request.auth.uid == resource.data.doctorId || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /diagnoses/{id} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.patientId || 
        request.auth.uid == resource.data.doctorId || 
        isAdmin()
      );
      allow create: if isDoctor() && request.resource.data.doctorId == request.auth.uid;
      allow update: if isDoctor() && resource.data.doctorId == request.auth.uid || isAdmin();
      allow delete: if isAdmin();
    }

    match /prescriptions/{id} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.patientId || 
        request.auth.uid == resource.data.doctorId || 
        isAdmin()
      );
      allow create: if isDoctor() && request.resource.data.doctorId == request.auth.uid;
      allow update: if isDoctor() && resource.data.doctorId == request.auth.uid || isAdmin();
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow read: if isChatParticipant(chatId);
      
      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId) && 
                      request.resource.data.senderId == request.auth.uid;
      }
    }

    match /notifications/{id} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated(); // Allow system or other users to create notifications
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }
  }
}
